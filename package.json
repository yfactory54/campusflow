{
  "name": "campusflow",
  "private": true,
  "version": "1.0.0",
  "description": "팀 업무 관리 협업 툴 — Node API + React 프론트엔드 모노레포",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "node --no-warnings --env-file-if-exists=.env apps/api/server.js",
    "dev:web": "npm run dev --workspace @campusflow/web",
    "dev": "npm run dev:api & npm run dev:web",
    "test": "npm run test --workspace @campusflow/api",
    "build": "npm run build --workspace @campusflow/web",
    "lint": "npm run lint --workspace @campusflow/web"
  },
  "engines": {
    "node": ">=22.9"
  }
}
