# ───────────────────────────────────────────────────────────
# CampusFlow 통합 환경 설정. 이 파일을 `.env` 로 복사해 사용하세요.
#   - 로컬 개발: 루트의 `npm run dev` / `dev:api` / `dev:web` 가 이 파일을 읽습니다.
#   - Docker:    `docker compose` 가 같은 디렉터리의 `.env` 를 자동으로 읽습니다.
# ───────────────────────────────────────────────────────────

# ── 포트 ──────────────────────────────────────────────────
# API_PORT: 백엔드/브라우저가 호출하는 API 포트
# WEB_PORT: 프론트엔드(웹) 접속 포트
API_PORT=4000
WEB_PORT=5173

# 프론트가 호출할 API 전체 주소를 직접 지정하고 싶을 때만 사용.
# 비워두면 자동으로 http://localhost:${API_PORT}/api/ 로 구성됩니다.
# VITE_API_BASE=http://localhost:4000/api/

# ── 보안/토큰 ─────────────────────────────────────────────
# 운영에서는 반드시 길고 무작위한 값으로 교체하세요.
TOKEN_SECRET=change-me-to-a-long-random-secret
TOKEN_TTL_SECONDS=604800
# 쉼표로 여러 Origin 허용 가능. 미설정 시 개발 편의상 모든 Origin 을 허용합니다.
CORS_ORIGIN=http://localhost:5173

# ── 초기 관리자 계정(최초 시드) ───────────────────────────
# ADMIN_PASSWORD 를 비워두면 무작위 생성되어 서버 로그에 1회 출력됩니다.
#   (Docker: `docker compose logs api`)
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=관리자
ADMIN_PASSWORD=
# 운영 비밀번호는 10자 이상이고 영문/숫자/특수문자 중 2종류 이상이어야 합니다.

# ── 데이터베이스 ──────────────────────────────────────────
# DB_PATH 는 보통 설정할 필요가 없습니다(자동 기본값).
#   - 로컬 실행: apps/api/data/app.db
#   - Docker:    /app/data/app.db (볼륨에 영구 저장)
# 굳이 바꿀 때만 주석을 해제하세요. (Docker 로 실행한다면 /app/data 아래 경로여야 볼륨에 저장됩니다.)
# DB_PATH=apps/api/data/app.db

# ── AI 기여도 분석용 LLM (OpenAI 호환 엔드포인트) ─────────
# 실제 엔드포인트/모델로 교체하세요. 미설정 시 기여도 분석 기능만 비활성화됩니다.
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=90000
